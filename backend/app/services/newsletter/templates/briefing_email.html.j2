<!doctype html>
<html lang="en" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="x-apple-disable-message-reformatting">
<meta name="format-detection" content="telephone=no,address=no,email=no,date=no">
<meta name="color-scheme" content="light only">
<meta name="supported-color-schemes" content="light only">
<title>The Retail Read &middot; Issue {{ issue_no }}</title>

<div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0;mso-hide:all;">
  {{ subhead }}
  &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847; &#847;
</div>

<!--[if mso]>
<noscript>
  <xml>
    <o:OfficeDocumentSettings>
      <o:PixelsPerInch>96</o:PixelsPerInch>
      <o:AllowPNG/>
    </o:OfficeDocumentSettings>
  </xml>
</noscript>
<![endif]-->

<!-- ====================================================================
     WEBFONT LOADING. Plus Jakarta Sans is the brand font for EVERYTHING
     (display, headlines, body, lede, pull-quote, byline, colophon).
     JetBrains Mono carries the mono labels/datelines/fig numbers.
     The serif family is intentionally dropped from the load + the stacks.
     ==================================================================== -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<!--[if !mso]><!-->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600;1,700;1,800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<!--<![endif]-->

<style>
  /* Client resets ----------------------------------------------------- */
  body, table, td, p, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
  table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; border-collapse:collapse; }
  img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; display:block; }
  p { margin:0; padding:0; }
  a { color:#F96302; text-decoration:none; }
  .ExternalClass { width:100%; }
  .ExternalClass, .ExternalClass p, .ExternalClass span, .ExternalClass font, .ExternalClass td, .ExternalClass div { line-height:100%; }

  @media only screen and (max-width: 480px) {
    .rr-container       { width:100% !important; max-width:100% !important; }
    .rr-pad             { padding-left:20px !important; padding-right:20px !important; }
    .rr-col-stack       { display:block !important; width:100% !important; max-width:100% !important; padding-left:0 !important; padding-right:0 !important; }
    .rr-col-stack-pad   { padding-left:20px !important; padding-right:20px !important; }
    .rr-toc             { border-left:0 !important; padding-left:0 !important; padding-top:18px !important; margin-top:12px !important; border-top:1px solid #c6bba8 !important; }
    .rr-mast            { font-size:44px !important; line-height:1.0 !important; }
    .rr-h1              { font-size:32px !important; line-height:1.04 !important; letter-spacing:-1.2px !important; }
    .rr-h2              { font-size:22px !important; line-height:1.18 !important; }
    .rr-spot            { font-size:26px !important; line-height:1.08 !important; }
    .rr-dropcap         { font-size:48px !important; padding-top:2px !important; }
    .rr-numeral         { font-size:26px !important; }
    .rr-pull            { font-size:18px !important; line-height:1.35 !important; }
    .rr-cta-cell        { display:block !important; width:100% !important; margin-bottom:10px !important; }
    .rr-cta-cell-last   { margin-bottom:0 !important; }
    .rr-colo-cell       { display:block !important; width:100% !important; text-align:left !important; padding:8px 0 !important; }
    .rr-hide-mobile     { display:none !important; }
    .rr-show-mobile     { display:block !important; max-height:none !important; overflow:visible !important; }
    .rr-spot-img        { width:100% !important; height:auto !important; }
  }

  @media (prefers-color-scheme: dark) {
    body, .rr-page, .rr-container { background:#f6f1e8 !important; color:#15110d !important; }
  }
  [data-ogsc] .rr-page, [data-ogsb] .rr-page { background:#f6f1e8 !important; color:#15110d !important; }
</style>

<!--[if mso]>
<style>
  /* Outlook desktop: Plus Jakarta Sans is stripped; fall back to Arial/
     Helvetica (NOT Georgia) so the whole layout stays sans. */
  .rr-serif      { font-family: Arial, Helvetica, sans-serif !important; }
  .rr-sans       { font-family: Arial, Helvetica, sans-serif !important; }
  .rr-mono       { font-family: Consolas, "Courier New", monospace !important; }
  table          { border-collapse: collapse !important; }
</style>
<![endif]-->
</head>

<body class="rr-page" style="margin:0;padding:0;background:#f6f1e8;color:#15110d;width:100%;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;">

<table role="presentation" class="rr-page" width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#f6f1e8" style="background:#f6f1e8;">
<tr><td align="center" style="padding:0;">

<!--[if mso | IE]>
<table role="presentation" align="center" width="600" cellpadding="0" cellspacing="0" border="0"><tr><td>
<![endif]-->

<table role="presentation" class="rr-container" width="600" cellpadding="0" cellspacing="0" border="0" align="center" style="width:600px;max-width:600px;margin:0 auto;background:#f6f1e8;">

  <!-- ── 01 · TOP DARK STRIP ─────────────────────────────────────── -->
  <tr><td bgcolor="#15110d" style="background:#15110d;padding:12px 24px;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td class="rr-mono" align="left"
            style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;line-height:1;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#f6f1e8;">
          Vol.&nbsp;{{ volume }} &nbsp;&middot;&nbsp; No.&nbsp;{{ issue_no }} &nbsp;&middot;&nbsp; {{ date_str }}
        </td>
        <td class="rr-sans" align="right"
            style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;line-height:1;letter-spacing:0.04em;font-weight:700;color:#f6f1e8;">
          <!-- Cloudera mark · inline text + dot (no SVG asset; SVG does not render in email clients) -->
          <span style="display:inline-block;width:11px;height:11px;border-radius:50%;background:#F96302;vertical-align:middle;margin-right:4px;">&nbsp;</span>CLOUDERA
        </td>
      </tr>
    </table>
  </td></tr>

  <!-- ── 02 · MASTHEAD ────────────────────────────────────────────── -->
  <tr><td class="rr-pad" align="center" style="padding:28px 24px 6px;">
    <p class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;line-height:1;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#5a4f43;margin:0 0 8px;">
      A bi-weekly briefing on AI in retail
    </p>
    <p class="rr-serif rr-mast" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:48px;line-height:1.0;letter-spacing:-1.6px;font-weight:800;color:#15110d;margin:0 0 8px;">
      The Retail&nbsp;<em style="font-style:italic;font-weight:500;">Read</em><span style="display:inline-block;width:7px;height:7px;background:#F96302;vertical-align:top;margin-left:3px;margin-top:6px;">&nbsp;</span>
    </p>
    <p class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;line-height:1.4;letter-spacing:0.16em;text-transform:uppercase;font-weight:600;color:#5a4f43;margin:0;">
      Edited by {{ author_name }} &nbsp;&middot;&nbsp; {{ author_title }} &nbsp;&middot;&nbsp; {{ author_company }}
    </p>
  </td></tr>

  <!-- ── 03 · DOUBLE RULE ─────────────────────────────────────────── -->
  <tr><td class="rr-pad" style="padding:18px 24px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td height="4" style="line-height:4px;font-size:0;background:#15110d;">&nbsp;</td></tr>
      <tr><td height="4" style="line-height:4px;font-size:0;">&nbsp;</td></tr>
      <tr><td height="1" style="line-height:1px;font-size:0;background:#15110d;">&nbsp;</td></tr>
    </table>
  </td></tr>

  <!-- ── 04 · HEADLINE + IN THIS ISSUE ────────────────────────────── -->
  <tr><td class="rr-pad" style="padding:22px 24px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td class="rr-col-stack" valign="top" width="360" style="width:360px;padding-right:16px;">
          <p class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;line-height:1;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#F96302;margin:0 0 10px;">
            {{ kicker }}
          </p>
          <h1 class="rr-serif rr-h1" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:36px;line-height:1.04;letter-spacing:-1.2px;font-weight:700;color:#15110d;margin:0 0 10px;">
            {{ headline_html | safe }}
          </h1>
          {% if subhead %}
          <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;line-height:1.4;color:#5a4f43;font-style:italic;margin:0 0 14px;">
            {{ subhead }}
          </p>
          {% endif %}
          <p class="rr-sans" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;line-height:1.45;color:#5a4f43;margin:0;">
            By <span style="color:#15110d;font-weight:600;border-bottom:1px solid #F96302;">{{ author_name }}</span>.
          </p>
        </td>

        <td class="rr-col-stack rr-toc" valign="top" width="176" style="width:176px;padding-left:18px;border-left:1px solid #c6bba8;">
          <p class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;line-height:1;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#15110d;margin:0 0 10px;">
            In this issue
          </p>
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="rr-sans"
                 style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;">
            {% for item in toc %}
            <tr><td style="padding:6px 0;{% if not loop.last %}border-bottom:1px dotted #c6bba8;{% endif %}font-size:12px;color:#15110d;font-weight:500;">
              <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#F96302;margin-right:4px;">{{ '%02d'|format(loop.index) }}</span> {{ item.label }}
              <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#5a4f43;float:right;letter-spacing:0.1em;">{{ item.ref }}</span>
            </td></tr>
            {% endfor %}
          </table>
        </td>
      </tr>
    </table>
  </td></tr>

  {% if hero_data_uri %}
  <!-- ── 05 · HERO IMAGE ──────────────────────────────────────────── -->
  <tr><td class="rr-pad" style="padding:24px 24px 0;">
    <img src="{{ hero_data_uri }}"
         width="552" height="auto"
         alt="{{ hero_caption or 'Hero image' }}"
         style="display:block;width:100%;max-width:552px;height:auto;border:1px solid #c6bba8;">
    {% if hero_caption %}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:8px;">
      <tr>
        <td class="rr-mono" align="left" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#5a4f43;font-weight:500;">
          FIG &middot; 01 &nbsp;&middot;&nbsp; {{ hero_caption }}
        </td>
        <td class="rr-mono" align="right" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#5a4f43;font-weight:500;">
          The Retail Read
        </td>
      </tr>
    </table>
    {% endif %}
  </td></tr>
  {% endif %}

  {% if the_read %}
  <!-- ── 06 · LEDE / BODY (single-column, drop cap, paragraph breaks) ── -->
  <tr><td class="rr-pad" style="padding:24px 24px 0;">
    <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;line-height:1.6;color:#15110d;margin:0;">
      <span class="rr-serif rr-dropcap"
            style="float:left;font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:58px;line-height:0.84;font-weight:800;color:#15110d;padding-right:8px;padding-top:6px;">{{ the_read_first_letter }}</span>{{ the_read_first_rest }}
    </p>
    {% for para in the_read_more_paragraphs %}
    <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;line-height:1.6;color:#15110d;margin:16px 0 0;">{{ para }}</p>
    {% endfor %}
  </td></tr>
  {% endif %}

  {% if pull_quote %}
  <!-- ── 09 · PULL QUOTE ──────────────────────────────────────────── -->
  <tr><td class="rr-pad" style="padding:28px 36px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td height="3" style="line-height:3px;font-size:0;background:#15110d;">&nbsp;</td></tr>
      <tr><td height="3" style="line-height:3px;font-size:0;">&nbsp;</td></tr>
      <tr><td height="1" style="line-height:1px;font-size:0;background:#15110d;">&nbsp;</td></tr>
    </table>
    <p class="rr-serif rr-pull" align="center"
       style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-style:italic;font-size:21px;line-height:1.3;letter-spacing:-0.3px;font-weight:500;color:#15110d;margin:18px 0;text-align:center;">
      &ldquo;{{ pull_quote }}&rdquo;
    </p>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td height="3" style="line-height:3px;font-size:0;background:#15110d;">&nbsp;</td></tr>
      <tr><td height="3" style="line-height:3px;font-size:0;">&nbsp;</td></tr>
      <tr><td height="1" style="line-height:1px;font-size:0;background:#15110d;">&nbsp;</td></tr>
    </table>
  </td></tr>
  {% endif %}

  {% if spotlight %}
  <!-- ── 10 · USE CASE SPOTLIGHT ─────────────────────────────────── -->
  <tr><td class="rr-pad" style="padding:30px 24px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="left" class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#F96302;">
          Use Case Spotlight &nbsp;&middot;&nbsp; B-section
        </td>
        {% if spotlight.tailored_for %}
        <td align="right" class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;font-weight:500;color:#5a4f43;">
          {{ spotlight.tailored_for }}
        </td>
        {% endif %}
      </tr>
    </table>
    <h2 class="rr-serif rr-spot" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:28px;line-height:1.08;letter-spacing:-0.8px;font-weight:700;color:#15110d;margin:6px 0 14px;">
      {{ spotlight.title }}
    </h2>

    {% if spotlight.image_data_uri %}
    <!-- Image runs the full content column, body stacks beneath (desktop + mobile). -->
    <img class="rr-spot-img"
         src="{{ spotlight.image_data_uri }}"
         width="552" height="auto"
         alt="{{ spotlight.title }} · system view"
         style="display:block;width:100%;max-width:552px;height:auto;border:1px solid #c6bba8;margin:0 0 16px;">
    {% endif %}
    {% for para in spotlight.paragraphs %}
    <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;line-height:1.58;color:#15110d;margin:{% if loop.first %}0{% else %}14px 0 0{% endif %};">
      {{ para }}
    </p>
    {% endfor %}
  </td></tr>
  {% endif %}

  {% if wins %}
  <!-- ── WINS & REFERENCES (between Spotlight and the Reading list) ── -->
  <tr><td class="rr-pad" style="padding:30px 24px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td class="rr-mono" align="left" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#15110d;">Wins &amp; References</td>
        <td class="rr-mono" align="right" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;font-weight:500;color:#5a4f43;">B-section</td>
      </tr>
    </table>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:6px;">
      <tr><td height="2" style="line-height:2px;font-size:0;background:#15110d;">&nbsp;</td></tr>
      <tr><td height="2" style="line-height:2px;font-size:0;">&nbsp;</td></tr>
      <tr><td height="1" style="line-height:1px;font-size:0;background:#15110d;">&nbsp;</td></tr>
    </table>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      {% for win in wins %}
      <tr>
        <td style="padding:11px 0;{% if not loop.last %}border-bottom:1px solid #c6bba8;{% endif %}">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
              <td valign="top" width="20" class="rr-mono" style="width:20px;font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:13px;font-weight:600;line-height:1.3;color:#F96302;">&middot;</td>
              <td valign="top">
                <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;font-weight:500;line-height:1.45;color:#15110d;margin:0;">{{ win }}</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
      {% endfor %}
    </table>
  </td></tr>
  {% endif %}

  {% if reading %}
  <!-- ── 11 · WHAT I'M READING (What's Moving) ───────────────────── -->
  <tr><td class="rr-pad" style="padding:30px 24px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td class="rr-mono" align="left" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#15110d;">What I&#39;m reading</td>
        <td class="rr-mono" align="right" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;font-weight:500;color:#5a4f43;">What&#39;s moving</td>
      </tr>
    </table>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:6px;">
      <tr><td height="2" style="line-height:2px;font-size:0;background:#15110d;">&nbsp;</td></tr>
      <tr><td height="2" style="line-height:2px;font-size:0;">&nbsp;</td></tr>
      <tr><td height="1" style="line-height:1px;font-size:0;background:#15110d;">&nbsp;</td></tr>
    </table>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      {% for item in reading %}
      <tr>
        <td style="padding:12px 0;{% if not loop.last %}border-bottom:1px solid #c6bba8;{% endif %}">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
              <td valign="top" width="28" class="rr-serif" style="width:28px;font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-style:italic;font-size:20px;font-weight:700;line-height:1;color:#F96302;">{{ loop.index }}.</td>
              <td valign="top">
                <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;font-weight:600;line-height:1.25;color:#15110d;margin:0;">{{ item }}</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
      {% endfor %}
    </table>
  </td></tr>
  {% endif %}

  {% if events %}
  <!-- ── 12 · ON THE HORIZON (vertical list, weighted orange bullets) ─ -->
  <tr><td class="rr-pad" style="padding:30px 24px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td class="rr-mono" align="left" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#15110d;">On The Horizon</td>
        <td class="rr-mono" align="right" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;font-weight:500;color:#5a4f43;">C-section</td>
      </tr>
    </table>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:6px;">
      <tr><td height="2" style="line-height:2px;font-size:0;background:#15110d;">&nbsp;</td></tr>
      <tr><td height="2" style="line-height:2px;font-size:0;">&nbsp;</td></tr>
      <tr><td height="1" style="line-height:1px;font-size:0;background:#15110d;">&nbsp;</td></tr>
    </table>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      {% for ev in events %}
      <tr>
        <td style="padding:13px 0;{% if not loop.last %}border-bottom:1px solid #c6bba8;{% endif %}">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
              <td valign="top" width="22" style="width:22px;padding-top:6px;">
                <span style="display:inline-block;width:9px;height:9px;background:#F96302;">&nbsp;</span>
              </td>
              <td valign="top">
                <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;font-weight:600;line-height:1.35;color:#15110d;margin:0;">{{ ev }}</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
      {% endfor %}
    </table>
  </td></tr>
  {% endif %}

  <!-- ── 13 · CTA BOX (dark) ─────────────────────────────────────── -->
  <tr><td class="rr-pad" style="padding:34px 24px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#15110d" style="background:#15110d;">
      <tr><td style="padding:22px 22px 22px;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td class="rr-cta-cell" valign="middle" width="46%" style="width:46%;padding-right:14px;">
              <p class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#f6f1e8;margin:0 0 6px;">Two ways forward</p>
              <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-style:italic;font-size:18px;line-height:1.3;font-weight:500;color:#f6f1e8;margin:0;">
                {{ footer_cta or "Reply with the part you disagree with. Or book thirty minutes on portfolio engineering for your retailer." }}
              </p>
            </td>
            <td class="rr-cta-cell" valign="middle" width="27%" style="width:27%;padding-right:8px;">
              <a href="mailto:{{ author_contact }}?subject={{ reply_subject }}"
                 style="display:block;text-decoration:none;border:1px solid #f6f1e8;padding:12px 14px;color:#f6f1e8;font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-weight:600;font-size:14px;line-height:1.3;">
                <span class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#F96302;display:block;margin-bottom:4px;">{{ reply_cta_heading }}</span>
                {{ reply_cta_body }}
              </a>
            </td>
            <td class="rr-cta-cell rr-cta-cell-last" valign="middle" width="27%" style="width:27%;">
              <a href="{{ booking_url }}"
                 style="display:block;text-decoration:none;background:#F96302;padding:12px 14px;color:#15110d;font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-weight:700;font-size:14px;line-height:1.3;">
                <span class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#15110d;display:block;margin-bottom:4px;">{{ book_cta_heading }}</span>
                {{ book_cta_body }}
              </a>
            </td>
          </tr>
        </table>
      </td></tr>
    </table>
  </td></tr>

  <!-- ── 14 · COLOPHON FOOTER ────────────────────────────────────── -->
  <tr><td class="rr-pad" style="padding:34px 24px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td height="3" style="line-height:3px;font-size:0;background:#15110d;">&nbsp;</td></tr>
      <tr><td height="3" style="line-height:3px;font-size:0;">&nbsp;</td></tr>
      <tr><td height="1" style="line-height:1px;font-size:0;background:#15110d;">&nbsp;</td></tr>
    </table>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;">
      <tr>
        <td class="rr-colo-cell" valign="top" width="40%" style="width:40%;">
          <p class="rr-sans" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-weight:700;font-size:13px;color:#15110d;margin:0 0 2px;">{{ author_name }}</p>
          <p class="rr-sans" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;color:#5a4f43;line-height:1.4;margin:0;">{{ author_title }}</p>
          <p class="rr-sans" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;color:#5a4f43;line-height:1.4;margin:0;">{{ author_company }}</p>
          <a href="mailto:{{ author_contact }}"
             class="rr-mono"
             style="display:inline-block;margin-top:6px;font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:11px;letter-spacing:0.04em;color:#F96302;text-decoration:none;border-bottom:1px solid #F96302;">
            {{ author_contact }}
          </a>
        </td>
        <td class="rr-colo-cell" valign="top" width="30%" align="center" style="width:30%;">
          <p class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;font-weight:600;color:#5a4f43;margin:0;">The Retail Read</p>
          <p class="rr-serif" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-style:italic;font-size:13px;font-weight:500;color:#15110d;margin:4px 0 0;">No.&nbsp;{{ issue_no }} &nbsp;&middot;&nbsp; {{ date_str }}</p>
        </td>
        <td class="rr-colo-cell" valign="top" width="30%" align="right" style="width:30%;">
          <p class="rr-sans" style="font-family:'Plus Jakarta Sans','Helvetica Neue',Helvetica,Arial,sans-serif;font-weight:700;font-size:12px;color:#15110d;margin:0 0 2px;">
            <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#F96302;vertical-align:middle;margin-right:4px;">&nbsp;</span>CLOUDERA
          </p>
          <p class="rr-mono" style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:9px;letter-spacing:0.06em;color:#5a4f43;margin:6px 0 0;line-height:1.4;">
            Set in Plus<br>Jakarta Sans
          </p>
        </td>
      </tr>
    </table>
    <p class="rr-mono" align="center"
       style="font-family:'JetBrains Mono',Consolas,'Courier New',monospace;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;color:#5a4f43;margin:28px 0 0;line-height:1.6;">
      Unsubscribe &nbsp;&middot;&nbsp; View in browser &nbsp;&middot;&nbsp; Forward
    </p>
  </td></tr>

  <!-- ── BOTTOM PAD ──────────────────────────────────────────────── -->
  <tr><td style="padding:24px 24px 36px;">&nbsp;</td></tr>

</table>

<!--[if mso | IE]>
</td></tr></table>
<![endif]-->

</td></tr>
</table>

</body>
</html>
